#!/usr/bin/env python3
"""mrc-probe — per-path SRv6 health probe (reflector + client) for the MRC NIC.

The MRC whitepaper (Araujo et al., "Resilient AI Supercomputer Networking using
MRC and SRv6") monitors path health with source-routed probes so there is "no
ambiguity about which path a probe packet takes" — ground truth about the
forwarding plane. This is that probe: each burst is SO_MARK-pinned to one SRv6
uSID carrier (the exact path the data plane would take), and measures the per-
path signals MRC reacts to — loss/liveness, latency, jitter, one-way delay, and
out-of-order (reordering).

It is a lightweight two-way (reflected) measurement, NOT RFC-5357 TWAMP on the
wire (no TWAMP-Control channel; a compact reflect format). Both ends are ours.

Subcommands:
  mrc-probe responder [[<bind>]:<port>]                 # UDP reflector; default [::]:20001
  mrc-probe probe <[host]:port> [--count N] [--interval MS] [--timeout S] [--mark M]

`probe` prints exactly ONE JSON line (what mrc-nic parses):
  {ok, tx, rx, loss_pct, rtt_min, rtt_avg, rtt_max, rtt_mdev, ob_avg, ib_avg,
   reorder, reorder_pct}
Delays in ms. --mark sets SO_MARK so the burst is pinned to a specific SRv6
fwmark route (the same carrier the data plane takes).

Timing: every timestamp is CLOCK_MONOTONIC (time.monotonic), which is a
system-wide clock on Linux — the sender's and reflector's timestamps are on the
same reference for any containers sharing the host kernel (as in this lab), so
the one-way deltas below are valid, not just the round trip.

Wire format (compact; both ends are ours):
  request  (12B): !I d        seq, t1  (sender transmit)
  reply    (28B): !I d d d     seq, t1, t2 (reflector receive), t3 (reflector transmit)
Sender, on receiving the reply at t4, derives per packet:
  rtt = (t4 - t1) - (t3 - t2)     # round trip minus reflector dwell
  ob  = t2 - t1                   # one-way outbound (the pinned path)
  ib  = t4 - t3                   # one-way inbound  (return path)
and counts a reorder whenever a reply's seq is lower than the highest seq
already received (out-of-order arrival — a first-class MRC path signal).
"""
import argparse, json, socket, struct, sys, time

REQ  = struct.Struct("!Id")      # seq, t1
REP  = struct.Struct("!Iddd")    # seq, t1, t2, t3
PORT = 20001

def _now():
    return time.monotonic()

def parse_target(s, default_port=PORT):
    """Accept '[ipv6]:port', 'ipv6' (bracketless literal), 'host:port', 'host'."""
    s = (s or "").strip()
    if s.startswith("["):
        host, _, rest = s[1:].partition("]")
        port = int(rest[1:]) if rest.startswith(":") and rest[1:] else default_port
        return host, port
    if s.count(":") > 1:             # bare IPv6 literal, no brackets -> no port in it
        return s, default_port
    host, _, p = s.partition(":")
    return host, (int(p) if p else default_port)

def responder(bind, port):
    s = socket.socket(socket.AF_INET6, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind((bind, port))
    sys.stderr.write(f"[mrc-twamp] responder on [{bind}]:{port}\n"); sys.stderr.flush()
    while True:
        try:
            data, addr = s.recvfrom(2048)
        except OSError:
            continue
        t2 = _now()
        if len(data) < REQ.size:
            continue
        seq, t1 = REQ.unpack(data[:REQ.size])
        t3 = _now()
        try:
            s.sendto(REP.pack(seq, t1, t2, t3), addr)
        except OSError:
            pass

def probe(target, count, interval_ms, timeout, mark):
    host, port = parse_target(target)
    fail = lambda err: print(json.dumps(
        {"ok": False, "err": err, "tx": count, "rx": 0, "loss_pct": 100.0,
         "reorder": 0, "reorder_pct": 0.0,
         "rtt_min": None, "rtt_avg": None, "rtt_max": None, "rtt_mdev": None,
         "ob_avg": None, "ib_avg": None}))
    try:
        ai = socket.getaddrinfo(host, port, socket.AF_INET6, socket.SOCK_DGRAM)[0][4]
    except OSError as e:
        return fail(f"resolve {host}: {e}")
    s = socket.socket(socket.AF_INET6, socket.SOCK_DGRAM)
    if mark:
        try:
            s.setsockopt(socket.SOL_SOCKET, socket.SO_MARK, int(mark))
        except OSError as e:
            return fail(f"SO_MARK {mark}: {e}")
    interval = max(0.0, interval_ms / 1000.0)
    # Send from a background thread while the main thread receives, so replies are
    # timestamped (t4) the instant they arrive instead of piling up in the socket
    # buffer behind the send loop's inter-packet sleeps. t1 is read back from the
    # reflector's echo, so there is no send-time table to race on.
    import threading
    send_err = {}
    def _sender():
        for seq in range(count):
            try:
                s.sendto(REQ.pack(seq, _now()), ai)
            except OSError as e:
                send_err["e"] = str(e); return
            if seq < count - 1 and interval:
                time.sleep(interval)
    th = threading.Thread(target=_sender, daemon=True); th.start()
    deadline = _now() + timeout
    seen = set(); rtts = []; obs = []; ibs = []
    max_seq = -1; reorder = 0        # out-of-order arrivals (a first-class MRC signal)
    s.settimeout(0.2)
    while len(seen) < count and _now() < deadline:
        try:
            data, _ = s.recvfrom(2048)
        except socket.timeout:
            if not th.is_alive() and "e" in send_err:
                break
            continue
        except OSError:
            break
        t4 = _now()
        if len(data) < REP.size:
            continue
        seq, t1, t2, t3 = REP.unpack(data[:REP.size])
        if seq in seen:
            continue
        seen.add(seq)
        if seq < max_seq:            # arrived after a higher seq already did
            reorder += 1
        else:
            max_seq = seq
        rtts.append(((t4 - t1) - (t3 - t2)) * 1000.0)
        obs.append(max(0.0, t2 - t1) * 1000.0)
        ibs.append(max(0.0, t4 - t3) * 1000.0)
    if not seen and "e" in send_err:
        return fail(f"send: {send_err['e']}")
    rx = len(seen)
    out = {"ok": rx > 0, "tx": count, "rx": rx,
           "loss_pct": round(100.0 * (count - rx) / count, 1) if count else 100.0,
           "reorder": reorder,
           "reorder_pct": round(100.0 * reorder / rx, 1) if rx else 0.0}
    if rtts:
        avg = sum(rtts) / len(rtts)
        out.update(rtt_min=round(min(rtts), 3), rtt_avg=round(avg, 3),
                   rtt_max=round(max(rtts), 3),
                   rtt_mdev=round((sum((x - avg) ** 2 for x in rtts) / len(rtts)) ** 0.5, 3),
                   ob_avg=round(sum(obs) / len(obs), 3),
                   ib_avg=round(sum(ibs) / len(ibs), 3))
    else:
        out.update(rtt_min=None, rtt_avg=None, rtt_max=None, rtt_mdev=None,
                   ob_avg=None, ib_avg=None, err="no reply")
    print(json.dumps(out))

def main():
    ap = argparse.ArgumentParser(prog="mrc-probe", description=__doc__.splitlines()[0])
    sub = ap.add_subparsers(dest="cmd", required=True)
    r = sub.add_parser("responder", help="run the UDP reflector")
    r.add_argument("bind", nargs="?", default=f"[::]:{PORT}")
    p = sub.add_parser("probe", help="send one measurement burst, print JSON")
    p.add_argument("target")
    p.add_argument("--count", type=int, default=20)
    p.add_argument("--interval", type=int, default=100, help="ms between packets")
    p.add_argument("--timeout", type=float, default=6.0)
    p.add_argument("--mark", type=int, default=0)
    a = ap.parse_args()
    if a.cmd == "responder":
        b, pt = parse_target(a.bind)
        responder(b or "::", pt)
    else:
        probe(a.target, a.count, a.interval, a.timeout, a.mark)

if __name__ == "__main__":
    main()
