def _decode_usid(hx, nxt=None):
    """Label a single 16-bit uSID hextet by its position-encoded meaning.
    Encoding (matches the generator's address_plan, post-aggregation layout):
      RPII  -> R=role(1=spine,2=leaf), P=plane, II=node index   (a uN/locator waypoint)
      eNNN  -> End.X function toward neighbor NNN (next-csid cross-connect on a spine/leaf)
      9LLL  -> the GPU block: nibble 9, LLL = home-leaf index; the FOLLOWING hextet is the
               local GPU index. Together block:9LLL:GGGG:: is a GPU's decap SID (End.DT6).
    Returns (short, detail) or None for an empty (0000) hextet."""
    if hx in ("0000", "0"):
        return None
    if hx.startswith("9"):
        leaf = int(hx[1:], 16)
        gg = (": gpu " + str(int(nxt, 16))) if nxt and nxt not in ("0000", "0") else ""
        return (f"leaf{leaf} GPU blk",
                f"GPU decap block for leaf{leaf}{gg} — terminal End.DT6; the destination NIC "
                f"strips the outer header here and delivers the inner packet")
    if hx.startswith("e"):
        n = hx[1:]
        return (f"End.X→{n}", f"End.X cross-connect function (toward neighbor {int(n,16)}); the "
                              f"spine does a next-csid shift, popping its locator+func pair")
    role = {"1": "spine", "2": "leaf"}.get(hx[0], "node")
    plane = hx[1]
    idx = int(hx[2:], 16)
    return (f"{role}{idx} loc", f"{role}{idx} locator (plane {plane}) — a uN waypoint; the packet "
                               f"is steered to {role}{idx}")


def _decode_carrier(usid):
    """Return (block, [(hextet, short, detail), ...]) for the meaningful uSIDs after the
    2-hextet block. Uses socket.inet_pton (already imported) to expand '::' rather than
    pulling in the ipaddress module."""
    try:
        packed = socket.inet_pton(socket.AF_INET6, usid)
    except OSError:
        return usid, []
    h = ["%02x%02x" % (packed[i], packed[i + 1]) for i in range(0, 16, 2)]
    block = ":".join(h[0:2])
    out = []
    rest = h[2:]
    i = 0
    while i < len(rest):
        hx = rest[i]
        nxt = rest[i + 1] if i + 1 < len(rest) else None
        d = _decode_usid(hx, nxt)
        if d:
            # a GPU block hextet (9LLL) consumes the following GPU-index hextet too
            if hx.startswith("9"):
                shown = f"{hx}:{nxt}" if nxt and nxt not in ("0000", "0") else hx
                out.append((shown, d[0], d[1]))
                i += 2
                continue
            out.append((hx, d[0], d[1]))
        i += 1
    return block, out


def cmd_paths(args):
    s = _read_state(resolve_state_path(args.state))
    decode = getattr(args, "decode", False)
    drained = set(s.get("drained") or [])

    def _is_drained(e):
        return e.get("path") in drained or e.get("spine") in drained

    def show_ev(e):
        sp = e.get("spine") or "same-leaf"
        usid = e.get("usid", "?")
        tag = "  [DRAINED — maintenance]" if _is_drained(e) else ""
        print(f"       EV {e.get('entropy','?'):>5}  via {sp:<8}  {usid}{tag}")
        if decode and usid != "?":
            block, hops = _decode_carrier(usid)
            print(f"          block {block}  +  {len(hops)} uSID(s):")
            for i, (hx, short, detail) in enumerate(hops, 1):
                print(f"            {i}. {hx}  [{short}]  {detail}")

    peers = s.get("peers")
    if isinstance(peers, dict) and peers:
        total = sum(len(v.get("active_evs", [])) for v in peers.values())
        ndr = sum(1 for v in peers.values()
                  for e in v.get("active_evs", []) if _is_drained(e))
        extra = f"  ({ndr} drained)" if ndr else ""
        print(f"mode=SRV6  peers={len(peers)}  total_evs={total}{extra}")
        for dst in sorted(peers):
            v = peers[dst]
            flow = v.get("flow") or {}
            name = flow.get("dst") or dst
            evs = v.get("active_evs", [])
            print(f"  -> {name} ({dst})  [{len(evs)} path{'s' if len(evs)!=1 else ''}]")
            for e in evs:
                show_ev(e)
        return
    p = s.get("profile") or {}
    print(f"mode={p.get('mode','-').upper()} active={len(p.get('active_evs',[]))}")
    for e in p.get("active_evs", []):
        show_ev(e)

def cmd_mesh_test(args):
    """Run a single mesh sweep synchronously and print exactly what happens:
    is ping present, what peers were learned, per-peer result, and (optionally)
    POST it. This isolates the three failure modes — no ping, no peers, POST
    rejected — without waiting on the background thread."""
    import threading as _t
    stop = _t.Event()
    m = MeshHealth(args.controller, args.host, stop)
    # 1. ping availability
    import shutil
    png = shutil.which("ping")
    print(f"ping binary: {png or 'NOT FOUND — install iputils-ping'}")
    # 2. peer discovery from the controller topology
    m._refresh_peers()
    if not m.peers:
        print(f"peers: NONE learned from {args.controller}/api/topology")
        print("  → is the controller reachable from this host? is topology populated?")
        return
    print(f"peers ({len(m.peers)}): " + ", ".join(f"{k}={v}" for k, v in m.peers.items()))
    # 3. one synchronous sweep
    samples = []
    for name, addr in m.peers.items():
        r = m._ping6(addr, MESH_COUNT, MESH_INTERVAL)
        up = r.get("rx", 0) > 0
        samples.append({"peer": name, "addr": addr, "up": up, **r})
        if up:
            print(f"  [✓] {name:<10} {addr}  loss {r.get('loss_pct',0):.1f}%  rtt {r.get('rtt_avg')} ms")
        else:
            print(f"  [✗] {name:<10} {addr}  {r.get('err') or 'unreachable (100% loss)'}")
    # 4. optional POST
    if args.post:
        m._post(samples)
        print(f"posted {len(samples)} samples → {args.controller}/api/mesh-health")
        try:
            import urllib.request as _u
            body = _u.urlopen(f"{args.controller.rstrip('/')}/api/diag", timeout=3).read().decode()
            print("controller /api/diag now:", body[:200])
        except Exception as e:
            print("diag check failed:", e)

